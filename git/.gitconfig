[core]
    excludesfile = ~/.gitignore_global
    editor = nvim
    pager = delta
[interactive]
    diffFilter = delta --color-only
[include]
    path = ~/.delta.themes.gitconfig
[delta]
    navigate = true
    side-by-side = true
    features = colibri
[merge]
    conflictstyle = diff3
[diff]
    colorMoved = default
# This is Git's per-user configuration file.
[user]
	name = Yuan
	email = isyuan@yeah.net
[alias]
    pso = push --set-upstream origin
    psu = push --set-upstream upstream
    plu = pull upstream
    dcp = !cur=$(git branch --show-current) && git switch master && git branch -D \"$cur\" && git pull upstream master
    dc = !cur=$(git branch --show-current) && git switch master && git branch -D \"$cur\"
[pull]
    rebase = false
[commit]
	template = ~/.gitCommitMsg
